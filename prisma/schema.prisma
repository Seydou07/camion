generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Camion {
  id                    Int       @id @default(autoincrement())
  immatriculation       String    @unique
  marque                String
  modele                String?
  capaciteTonnes        Float     @map("capacite_tonnes")
  statut                String    @default("en_service")
  dateMiseService       DateTime  @map("date_mise_service")
  prochaineVisite       DateTime? @map("prochaine_visite")
  createdAt             DateTime  @default(now()) @map("created_at")
  chauffeurId           Int?      @unique @map("chauffeur_id")
  kilometrageActuel     Int       @default(0) @map("kilometrage_actuel")
  annee                 Int?
  capaciteReservoir     Int?      @map("capacite_reservoir")
  carburant             String    @default("Diesel")
  compagnieAssurance    String?   @map("compagnie_assurance")
  couleur               String?
  dotationAnnuelle      Float?    @map("dotation_annuelle")
  echeanceAssurance     DateTime? @map("echeance_assurance")
  frequenceVidange      Int?      @map("frequence_vidange")
  notes                 String?   @db.Text
  numeroChassis         String?   @map("numero_chassis")
  numeroPoliceAssurance String?   @map("numero_police_assurance")
  transmission          String?   @default("Manuelle")
  dernierKilometrageVidange Int   @default(0) @map("dernier_kilometrage_vidange")
  budgetConsomme        Float     @default(0) @map("budget_consomme")
  budgetRestant         Float     @default(0) @map("budget_restant")

  chauffeur              Chauffeur?           @relation(fields: [chauffeurId], references: [id], onDelete: SetNull)
  carburants             Carburant[]
  reparations            Reparation[]
  maintenancesPlanifiees MaintenancePlanifiee[]
  voyages                Voyage[]

  @@map("camions")
}

model Chauffeur {
  id           Int      @id @default(autoincrement())
  nom          String
  prenom       String?
  telephone    String?
  numeroPermis String?  @map("numero_permis")
  statut       String   @default("actif")
  createdAt    DateTime @default(now()) @map("created_at")

  camion      Camion?
  carburants  Carburant[]
  voyages     Voyage[]

  @@map("chauffeurs")
}

model Carburant {
  id               Int                  @id @default(autoincrement())
  voyageId         Int?                 @unique @map("voyage_id")
  voyage           Voyage?              @relation(fields: [voyageId], references: [id], onDelete: Cascade)
  camionId         Int                  @map("camion_id")
  camion           Camion               @relation(fields: [camionId], references: [id], onDelete: Cascade)
  chauffeurId      Int?                 @map("chauffeur_id")
  chauffeur        Chauffeur?           @relation(fields: [chauffeurId], references: [id], onDelete: SetNull)
  montantPrevision Float                @default(0) @map("montant_prevision")
  totalComplements Float                @default(0) @map("total_complements")
  totalDepenses    Float                @default(0) @map("total_depenses")
  totalRecuValide  Float                @default(0) @map("total_recu_valide")
  statut           String               @default("EN_COURS") @map("statut")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  mouvements       MouvementCarburant[]

  @@index([camionId], map: "carburants_camion_id_fkey")
  @@index([chauffeurId], map: "carburants_chauffeur_id_fkey")
  @@map("carburants")
}

model MouvementCarburant {
  id            Int             @id @default(autoincrement())
  carburantId   Int             @map("carburant_id")
  carburant     Carburant       @relation(fields: [carburantId], references: [id], onDelete: Cascade)
  dateOperation DateTime        @default(now()) @map("date_operation")
  typeOperation String          @map("type_operation") // "PREVISION", "COMPLEMENT", "DEPENSE", "AJUSTEMENT"
  montant       Float           @map("montant")
  stationService String?        @map("station_service")
  numeroTicket  String?         @map("numero_ticket")
  kilometrage   Int?            @map("kilometrage")
  litres        Float?          @map("litres")
  prixLitre     Float?          @map("prix_litre")
  commentaire   String?         @db.Text @map("commentaire")
  utilisateurId Int?            @map("utilisateur_id")
  createdAt     DateTime        @default(now()) @map("created_at")

  recus         RecuCarburant[]

  @@index([carburantId], map: "mouvements_carburant_carburant_id_fkey")
  @@map("mouvements_carburant")
}

model RecuCarburant {
  id          Int                @id @default(autoincrement())
  mouvementId Int                @map("mouvement_id")
  mouvement   MouvementCarburant @relation(fields: [mouvementId], references: [id], onDelete: Cascade)
  cheminImage String             @map("chemin_image")
  nomFichier  String?            @map("nom_fichier")
  mimeType    String?            @map("mime_type")
  tailleOctets Int?              @map("taille_octets")
  montantRecu Float              @map("montant_recu")
  dateRecu    DateTime           @default(now()) @map("date_recu")
  commentaire String?            @db.Text @map("commentaire")
  createdAt   DateTime           @default(now()) @map("created_at")

  @@index([mouvementId], map: "recu_carburants_mouvement_id_fkey")
  @@map("recu_carburants")
}

model Voyage {
  id                         Int        @id @default(autoincrement())
  numeroVoyage               String     @unique @map("numero_voyage")
  camionId                   Int        @map("camion_id")
  camion                     Camion     @relation(fields: [camionId], references: [id], onDelete: Cascade)
  chauffeurId                Int?       @map("chauffeur_id")
  chauffeur                  Chauffeur? @relation(fields: [chauffeurId], references: [id], onDelete: SetNull)
  dateDebut                  DateTime   @default(now()) @map("date_debut")
  dateFin                    DateTime?  @map("date_fin")
  kilometrageDepart          Int        @map("kilometrage_depart")
  kilometrageArrivee         Int?       @map("kilometrage_arrivee")
  montantPrevisionCarburant  Float      @default(0) @map("montant_prevision_carburant")
  observations               String?    @db.Text @map("observations")
  statut                     String     @default("EN_COURS") @map("statut")
  destination                String
  createdAt                  DateTime   @default(now()) @map("created_at")
  updatedAt                  DateTime   @updatedAt @map("updated_at")

  carburant                  Carburant?

  @@index([camionId], map: "voyages_camion_id_fkey")
  @@index([chauffeurId], map: "voyages_chauffeur_id_fkey")
  @@map("voyages")
}

model Reparation {
  id               Int       @id @default(autoincrement())
  camionId         Int       @map("camion_id")
  camion           Camion    @relation(fields: [camionId], references: [id], onDelete: Cascade)
  date             DateTime  @default(now())
  type             String
  garage           String
  description      String    @db.Text
  cout             Float
  createdAt        DateTime  @default(now()) @map("created_at")
  kilometrage      Int       @default(0)
  carteCarburantId Int?      @map("carte_carburant_id")
  dateFin          DateTime? @map("date_fin")
  mainOeuvreCout   Float     @default(0) @map("main_oeuvre_cout")
  mainOeuvreSource String?   @map("main_oeuvre_source")
  reference        String?
  statut           String    @default("terminee")

  piecesChangees PieceChangee[]

  @@index([camionId], map: "reparations_camion_id_fkey")
  @@map("reparations")
}

model PieceChangee {
  id             Int        @id @default(autoincrement())
  reparationId   Int        @map("reparation_id")
  reparation     Reparation @relation(fields: [reparationId], references: [id], onDelete: Cascade)
  nom            String
  quantite       Int
  prixUnitaire   Float      @map("prix_unitaire")
  sourcePaiement String?    @map("source_paiement")

  @@index([reparationId], map: "pieces_changees_reparation_id_fkey")
  @@map("pieces_changees")
}

model CarteCarburant {
  id          Int      @id @default(autoincrement())
  numeroCarte String   @unique @map("numero_carte")
  solde       Float    @default(0)
  statut      String   @default("actif")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("cartes_carburant")
}

model MaintenancePlanifiee {
  id                   Int       @id @default(autoincrement())
  camionId             Int       @map("camion_id")
  camion               Camion    @relation(fields: [camionId], references: [id], onDelete: Cascade)
  type                 String
  description          String?   @db.Text
  frequenceKilometrage Int?      @map("frequence_kilometrage")
  kilometrageDernier   Int       @default(0) @map("kilometrage_dernier")
  kilometrageCible     Int       @map("kilometrage_cible")
  dateLimite           DateTime? @map("date_limite")
  statut               String    @default("planifie")
  createdAt            DateTime  @default(now()) @map("created_at")

  @@index([camionId], map: "maintenances_planifiees_camion_id_fkey")
  @@map("maintenances_planifiees")
}

model ParametreGlobal {
  id               Int      @id @default(autoincrement())
  cle              String   @unique
  valeur           String
  description      String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("parametres_globaux")
}
